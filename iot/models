int ledPin = 13;
int sensorPin = 49;
int obstacleDetected = LOW;

void setup() {
  pinMode(ledPin, OUTPUT);
  pinMode(sensorPin, INPUT);
  Serial.begin(9600);
}
void loop() {
  obstacleDetected = digitalRead(sensorPin);
  if (obstacleDetected == LOW) {
    Serial.println("Stop! obstacle detected");
    digitalWrite(ledPin, HIGH);
  } else {
    Serial.println("No Obstacle, Go ahead!");
    digitalWrite(ledPin, LOW);
  }
  delay(200);}

Ultrasonic sensor

const int trig = 3;
const int echo = 2;
long roundtriptime;
int dist;

void setup() {
  pinMode(trig, OUTPUT);
  pinMode(echo, INPUT);
  Serial.begin(9600);}

void loop() {
  digitalWrite(trig, LOW);
  delayMicroseconds(2);
  digitalWrite(trig, HIGH);
  delayMicroseconds(10);
  digitalWrite(trig, LOW);
  roundtriptime = pulseIn(echo, HIGH);
  dist = (roundtriptime / 2) * 0.034;
  Serial.print("Distance: ");
  Serial.println(dist);}

