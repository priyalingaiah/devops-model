#include "ThingSpeak.h"
#include <WiFi.h>

char ssid[] = "OnePlusNord4";
char pass[] = "password";

WiFiClient client;

const int trigPin = 5;   // Ultrasonic trigger
const int echoPin = 18;  // Ultrasonic echo

unsigned long myChannelField = number;   // Channel ID
const int DistanceField = 2;             // Field for distance
const char* myWriteAPIKey = "paste here";

void setup() {
  Serial.begin(115200);
  pinMode(trigPin, OUTPUT);
  pinMode(echoPin, INPUT);
  ThingSpeak.begin(client);
  delay(500);}

void loop() {
  if (WiFi.status() != WL_CONNECTED) {
    while (WiFi.status() != WL_CONNECTED) {
      WiFi.begin(ssid, pass);
      delay(5000);
   }  }

  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);
  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);

  long duration = pulseIn(echoPin, HIGH);
  float distance = (duration / 2.0) * 0.034;

  Serial.print("Distance: ");
  Serial.println(distance);

  ThingSpeak.writeField(myChannelField, DistanceField, distance, myWriteAPIKey);

  delay(1000);}

